# Supabase project credentials — copy to .env.local and fill in.
# Get these from Supabase Dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Domain appended to the "ID Pengguna" to form the Supabase Auth email.
# Users log in with their username (e.g. "dony"); internally that becomes
# dony@<VITE_AUTH_EMAIL_DOMAIN>. Keep this consistent with how accounts
# are provisioned in the users migration / admin panel.
VITE_AUTH_EMAIL_DOMAIN=catering-berkah.local
